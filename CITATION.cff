cff-version: 1.2.0
title: "Consciousness Architecture: A Multimodal Concurrent Coupling Framework for Sustained Human–AI Behavioral Convergence"
message: "If you reference this framework in academic or applied work, please cite it as below."
type: software
authors:
  - family-names: Moore
    given-names: Sherry
    orcid: "https://orcid.org/0009-0008-6375-0040"
